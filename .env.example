# DVLA Vehicle Enquiry API
DVLA_API_KEY=your-dvla-api-key

# DVSA MOT History API (OAuth2 + API key)
MOT_CLIENT_ID=your-client-id
MOT_CLIENT_SECRET=your-client-secret
MOT_API_KEY=your-api-key
MOT_SCOPE_URL=https://tapi.dvsa.gov.uk/.default
MOT_TOKEN_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
